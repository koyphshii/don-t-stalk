# Neon Postgres — use the POOLED connection for app queries
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.us-east-2.aws.neon.tech/mosted?sslmode=require"
# Direct connection for Prisma migrations only
DIRECT_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/mosted?sslmode=require"

# Auth.js
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Discord OAuth
# Create an app at https://discord.com/developers/applications
# Set redirect URI to: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Tenor GIF API (optional — landing page falls back to static content without it)
NEXT_PUBLIC_TENOR_API_KEY=""

# Vercel Blob (optional — for avatar uploads in production)
BLOB_READ_WRITE_TOKEN=""
